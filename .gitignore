# macOS
.DS_Store
*.swp

# Xcode / build artifacts
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Generated by XcodeGen from project.yml — run `xcodegen generate` to recreate.
# (Committing it causes churn and can leak local Xcode state.)
# Glob also catches macOS "Oatmeal 2.xcodeproj" duplicates.
Oatmeal*.xcodeproj/

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# Installed app symlinks (recreated by reinstall.sh)
/Oatmeal.app
/Oatmeal*.app

# Release build artifacts (signed zips). The appcast in docs/ IS committed; the
# binaries are uploaded to GitHub Releases, not git. See release.sh.
/dist/

# Signing material / local secrets
*.p12
*.p8
*.pem
*.key
*.cer
*.cert
*.mobileprovision
*.provisionprofile
ExportOptions.plist
key.priv
.env
.env.*

# Local tooling / editor config
.claude/
.vscode/
.idea/

# Local screenshots / scratch
Screenshot*.png
*.scratch
