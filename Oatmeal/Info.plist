	<string>Oatmeal reads your calendar to title recordings and show your upcoming meetings.</string>
	<key>NSRemindersUsageDescription</key>
	<string>Oatmeal can add your meeting action items to Apple Reminders.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>Oatmeal can add your meeting action items to Apple Reminders.</string>
