<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Oatmeal records your microphone to transcribe what you say during meetings.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>Oatmeal reads your calendar to title recordings and show your upcoming meetings.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Oatmeal reads your calendar to title recordings and show your upcoming meetings.</string>
	<key>NSRemindersUsageDescription</key>
	<string>Oatmeal can add your meeting action items to Apple Reminders.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>Oatmeal can add your meeting action items to Apple Reminders.</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<!-- Sparkle auto-updater. Appcast served over HTTPS from GitHub Pages
	     (docs/appcast.xml). SUPublicEDKey is the public half of the EdDSA key
	     whose private half lives in the release machine's Keychain; Sparkle
	     verifies every update against it. plans/015-one-click-updates-sparkle.md -->
	<key>SUFeedURL</key>
	<string>https://superluis0.github.io/Oatmeal/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>z8Wip8HXiwv1Jg1OyCAORHDvtUUZDju7Sl0KOfEwk6Q=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- Background check cadence for a long-running instance (seconds). 7200 = 2h,
	     so testers leaving Oatmeal open pick up a release within a couple hours;
	     a relaunch surfaces it immediately. Sparkle's default is 86400 (24h). -->
	<key>SUScheduledCheckInterval</key>
	<integer>7200</integer>
</dict>
</plist>
